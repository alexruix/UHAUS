---
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import Image from "astro/components/Image.astro";
import { getEntry } from "astro:content";

const global_settings = await getEntry("settings", "global");
const { site } = global_settings!.data;
const { logo } = site;
const entry = await getEntry("pages", "404");
if (!entry) {
  throw new Error("404 page not found in content collection");
}
const { Content } = await entry.render();
---

<Base title={entry.data.title} noindex={true}>
  <section class="section h-screen flex items-center justify-center bg-gradient-to-r from-slate-50 to-neutral-50">
    <div class="container">
      <div class="text-center flex flex-col items-center">
        <div class="mb-6 animate__animated animate__flash animate__delay-2s">
          <Image
            src="/images/404.webp"
            class="mb-4 inline"
            alt="404"
            height={120}
            width={120}
          />
        </div>

        <h1 class="text-6xl font-bold mb-4" set:html={markdownify(entry.data.title)}></h1>

        <div class="text-lg mb-6 max-w-lg">
          <Content />
        </div>

        <a href="/" class="btn btn-primary mt-6 px-8 py-4 text-lg font-semibold">
          Volver al Inicio
        </a>
      </div>
    </div>
  </section>
</Base>
