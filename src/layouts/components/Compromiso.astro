---
import Icon from "@/layouts/components/Icon.astro";
import { markdownify } from "@/lib/utils/textConverter";
import Card from "@/components/Card.astro";

interface Props {
  graph: {
    head: string;
    description: string;
  };
  graph_data: any[];
  future_data: any[];
  id?: string;
}

const { graph, graph_data, future_data, id } = Astro.props;
---

<section class="section" id={id}>
  <div class="container px-4 mx-auto">
    <div class="mb-10 text-center">
      <h2 class="h2 mb-4">{graph.head}</h2>
      <p class="text-lg max-w-3xl mx-auto">{graph.description}</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 flex-1 md:p-8 lg:p-8 rounded bg-clip-padding backdrop-filter backdrop-blur-lg border-gray-200 border stagger-container">
        {graph_data.map((item: any) => (
          <div
            class="relative p-8 border-4 cursor-pointer mycard shadow bg-white rounded transition-transform duration-500 ease-in-out lg:hover:scale-105 group reveal reveal-up"
            style={`border-color: ${item.color};`}
          >
            <div class="flex flex-col items-center">
              <div class="flex gap-4 text-uhausG">
                <Icon name={item.icon} size={32} />
                <h3 class="font-bold h5 text-center text-uhausG">{item.title}</h3>
              </div>
            </div>

            <div class="max-h-full lg:max-h-0 lg:overflow-hidden transition-all duration-500 ease-in-out group-hover:max-h-48 lg:group-hover:opacity-100 opacity-100 lg:opacity-0">
              <p class="mt-4 text-gray-700">
                <span set:html={markdownify(item.content)} />
              </p>

              {item.button && (
                <div class="mt-4 flex justify-center">
                  <a
                    class={`btn mx-2 ${item.button?.outline ? "btn-outline-primary" : "btn-primary"}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    href={item.button?.link}
                  >
                    {item.button?.icon && (
                      <Icon name={item.button.icon} size={20} />
                    )}
                    {item.button?.label}
                  </a>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>

      <div class="flex flex-col gap-8 flex-none w-full lg:w-1/3">
        {future_data.map((post: any) => (
          <Card title={post.title} description={post.content} />
        ))}
      </div>
    </div>
  </div>
</section>
