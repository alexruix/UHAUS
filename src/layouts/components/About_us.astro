---
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
const { data, id } = Astro.props;
const { title, image, content } = data;
---

<section class="section banner relative" id={id}>
  <div class="container px-4 mx-auto">
    <div class="row items-center">
      <div class="col-12 lg:col-5">
        <div class="relative mx-auto lg:mx-0">
          <!-- <div class="absolute -inset-3 bg-uhausG/10 rounded-2xl -z-10 transform translate-y-3 -translate-x-3"></div> -->
          
          <Image
            class="w-full h-auto object-contain rounded"
            alt={title}
            src={image}
            width={603}
            height={396}
          />
        </div>
      </div>

      <div class="col-12 lg:col-6">
        <h2
          class="text-3xl lg:text-4xl font-extrabold leading-tight text-dark mb-2 relative inline-block"
        >
          <span set:html={markdownify(title)} />
          <!-- <span class="absolute -bottom-2 left-0 w-1/3 h-1 bg-uhausG rounded-full"></span> -->
        </h2>

        <div
          class="mt-6 text-[17px] lg:text-lg leading-relaxed text-text/90 prose-p:mb-4"
          set:html={markdownify(content)}
        />
      </div>
    </div>
  </div>
</section>
