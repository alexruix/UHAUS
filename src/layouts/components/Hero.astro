---
const { title, image, buttons, content, banner, id } = Astro.props;
import PageHeader from "@/components/PageHeader.astro";
import Image from "astro/components/Image.astro";
import { markdownify } from "@/lib/utils/textConverter";
---

<section class="page-hero pb-14 relative" id={id}>
  <div class="relative">
    <div class="page-hero-content z-0 mx-auto text-center relative">

      <PageHeader page_data={{ title, image, buttons, content }} />
    </div>


    <div class="container relative z-10 -mt-16">
      <div class="bg-white rounded-xl py-6 px-4 shadow-xl max-w-[1000px] mx-auto">
        <div class="flex flex-wrap justify-center">
          {
            banner.map((item: any, i: number) => (
              <div class="w-full sm:w-1/2 md:w-1/3 flex flex-col items-center gap-2 py-4 px-4">
                <div class="flex w-full items-center gap-2.5">
                  <Image
                    class="w-14 h-14 object-contain"
                    alt={item.title}
                    src={item.image}
                    width={56}
                    height={56}
                  />
                  <h2 class="h3 text-uhaus mb-0">{item.title}</h2>
                </div>
                <p class="mt-1 text-base leading-relaxed text-text">{item.subtitle}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
