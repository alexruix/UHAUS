---
const { posts } = Astro.props; // Recibe el prop `posts`
import Videos from "@/layouts/components/Videos.astro";
import Card from "@/layouts/components/Card.astro";
import { Image } from "astro:assets";
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-container">
  {
    posts.map((post: any) => (
      <Card
        image={post.image}
        noShadow={true}
        className="border border-border reveal reveal-up"
      >
        {post.video && (
          <div class="mb-3">
            <Videos
              src={post.video.thumbnail}
              height={370}
              width={700}
              title={post.title}
              video_path={post.video.video_path}
              video_width="w-[700px]"
              video_height="h-[370px]"
            />
          </div>
        )}
        <h3 class="text-lg font-bold text-dark mb-1">{post.title}</h3>
        <p class="text-sm text-text leading-relaxed">{post.description}</p>
      </Card>
    ))
  }
</div>
