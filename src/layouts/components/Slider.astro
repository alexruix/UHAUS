---
import { CaretLeft, CaretRight } from "@phosphor-icons/react";
import Card from "./Card.astro";

interface SliderItem {
  organization: string;
  content: string;
}

interface Props {
  list: SliderItem[];
}

const { list } = Astro.props;
const uniqueId = `slider-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="testimonial-slider relative w-full group py-4" id={uniqueId}>
  {/* -- Background Decoration -- */}
  <div class="absolute -inset-x-4 inset-y-0 bg-gray-50/30 -z-10 rounded-3xl transform skew-y-1"></div>

  {/* -- Track -- */}
  <div
    data-track
    class="flex overflow-x-auto snap-x snap-mandatory gap-6
           pb-12 pt-4 px-2 scrollbar-hide scroll-smooth"
  >
    {list.map((item, i) => (
      <div class="snap-start flex-none w-[85%] md:w-[46%] lg:w-[31%] h-auto">
        <Card title={item.organization}>
          <div class="review-content relative overflow-hidden transition-all duration-500 ease-in-out max-h-[160px]" data-expandable>
            <p class="text-text/90 text-[15px] leading-relaxed whitespace-pre-line">
              {item.content}
            </p>
            <div class="fade-overlay absolute bottom-0 left-0 right-0 h-12 bg-linear-to-t from-white to-transparent transition-opacity duration-300"></div>
          </div>

          {item.content.length > 200 && (
            <button
              class="text-primary text-sm font-bold text-left hover:text-primary/80 transition-colors mt-4 flex items-center gap-2 group/btn"
              data-expand-btn
            >
              <span class="relative">
                <span class="btn-text">Ver más</span>
                <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary group-hover/btn:w-full transition-all duration-300"></span>
              </span>
            </button>
          )}
        </Card>
      </div>
    ))}
  </div>

  <div class="hidden md:block">
    <button
      data-prev
      aria-label="Anterior"
      class="absolute -left-6 top-1/2 -translate-y-1/2 z-20
             w-12 h-12 flex items-center justify-center
             rounded-full bg-white shadow-xl border border-gray-100
             text-dark transition-all duration-300 opacity-0 scale-75 pointer-events-none hover:bg-primary hover:text-white"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256"><path d="M168,224a8,8,0,0,1-5.66-2.34l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L101.31,128l72.35,72.34A8,8,0,0,1,168,224Z"></path></svg>
    </button>

    <button
      data-next
      aria-label="Siguiente"
      class="absolute -right-6 top-1/2 -translate-y-1/2 z-20
             w-12 h-12 flex items-center justify-center
             rounded-full bg-white shadow-xl border border-gray-100
             text-dark transition-all duration-300 opacity-100 scale-100 hover:bg-primary hover:text-white"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256"><path d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L154.69,128,90.34,63.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z"></path></svg>
    </button>
  </div>

  {/* -- Pagination dots -- */}
  <div class="flex items-center justify-center gap-3 mt-4" data-pagination>
    {list.map((_, i) => (
      <button
        data-index={i}
        class="group/dot p-2 transition-all duration-300"
        aria-label={`Ir al slide ${i + 1}`}
      >
        <div class={`dot-pill h-2 rounded-full transition-all duration-500 ease-out ${i === 0 ? "w-8 bg-primary" : "w-2 bg-gray-300"}`}></div>
      </button>
    ))}
  </div>
</div>

<script define:vars={{ uniqueId, total: list.length }}>
  const container = document.getElementById(uniqueId);
  const track = container?.querySelector('[data-track]');
  const prevBtn = container?.querySelector('[data-prev]');
  const nextBtn = container?.querySelector('[data-next]');
  const dots = container?.querySelectorAll('.dot-pill');
  const expandBtns = container?.querySelectorAll('[data-expand-btn]');

  const updateUI = () => {
    if (!track) return;
    const { scrollLeft, scrollWidth, clientWidth } = track;
    
    if (prevBtn) {
      if (scrollLeft > 10) {
        prevBtn.classList.remove('opacity-0', 'scale-75', 'pointer-events-none');
        prevBtn.classList.add('opacity-100', 'scale-100');
      } else {
        prevBtn.classList.add('opacity-0', 'scale-75', 'pointer-events-none');
        prevBtn.classList.remove('opacity-100', 'scale-100');
      }
    }

    if (nextBtn) {
      if (scrollLeft + clientWidth < scrollWidth - 10) {
        nextBtn.classList.remove('opacity-0', 'scale-75', 'pointer-events-none');
        nextBtn.classList.add('opacity-100', 'scale-100');
      } else {
        nextBtn.classList.add('opacity-0', 'scale-75', 'pointer-events-none');
        nextBtn.classList.remove('opacity-100', 'scale-100');
      }
    }

    // Update active dot
    const firstSlide = track.children[0];
    if (firstSlide) {
      const slideWidth = firstSlide.offsetWidth + 24;
      const activeIndex = Math.round(track.scrollLeft / slideWidth);
      dots?.forEach((dot, i) => {
        if (i === activeIndex) {
          dot.classList.add('w-8', 'bg-primary');
          dot.classList.remove('w-2', 'bg-gray-300');
        } else {
          dot.classList.remove('w-8', 'bg-primary');
          dot.classList.add('w-2', 'bg-gray-300');
        }
      });
    }
  };

  const scrollTo = (index) => {
    const firstSlide = track?.children[0];
    if (firstSlide) {
      const slideWidth = firstSlide.offsetWidth + 24;
      track.scrollTo({ left: index * slideWidth, behavior: 'smooth' });
    }
  };

  prevBtn?.addEventListener('click', () => {
    const firstSlide = track?.children[0];
    const slideWidth = firstSlide?.offsetWidth + 24;
    const activeIndex = Math.round(track.scrollLeft / slideWidth);
    scrollTo(activeIndex - 1);
  });

  nextBtn?.addEventListener('click', () => {
    const firstSlide = track?.children[0];
    const slideWidth = firstSlide?.offsetWidth + 24;
    const activeIndex = Math.round(track.scrollLeft / slideWidth);
    scrollTo(activeIndex + 1);
  });

  dots?.forEach((dot, i) => {
    dot.parentElement.addEventListener('click', () => scrollTo(i));
  });

  track?.addEventListener('scroll', updateUI, { passive: true });
  window.addEventListener('resize', updateUI);

  // Expandable logic
  expandBtns?.forEach((btn) => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('.card');
      const content = parent?.querySelector('[data-expandable]');
      const fade = parent?.querySelector('.fade-overlay');
      const btnText = btn.querySelector('.btn-text');
      
      if (content?.classList.contains('max-h-[160px]')) {
        content.classList.remove('max-h-[160px]');
        content.classList.add('max-h-[1000px]');
        fade?.classList.add('opacity-0');
        if (btnText) btnText.textContent = 'Ver menos';
      } else {
        content?.classList.add('max-h-[160px]');
        content?.classList.remove('max-h-[1000px]');
        fade?.classList.remove('opacity-0');
        if (btnText) btnText.textContent = 'Ver más';
      }
    });
  });

  updateUI();
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
