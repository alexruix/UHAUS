---
import Logo from "@/components/Logo.astro";
import menu from "@/config/menu.json";
import { getEntry } from "astro:content";
import { markdownify } from "@/lib/utils/textConverter";
import Icon from "@/layouts/components/Icon.astro";

const global_settings = await getEntry("settings", "global");
const { site, params } = global_settings!.data;
const { footer } = menu;
const currentYear = new Date().getFullYear();
const { whatsapp } = site;
const { copyright, location, email, phone, instagram } = params;
---

<footer class="footer bg-[#F1F1F1]">
  <div class="container">
    <div
      class="row flex flex-wrap justify-between items-start space-around pb-10 pt-[52px]"
    >
      <div class="flex flex-col mt-12 md:w-1/3 lg:w-1/4">
        <Logo />
      </div>

      <div class="flex flex-col mt-12 md:w-2/3 lg:w-3/4">
        <div class="flex gap-8 justify-end">
          <div class="flex flex-col">
            <h6>Menú</h6>
            <ul>
              {
                footer.map((item, i) => (
                  <li class={footer.length - 1 === i ? "mb-0" : "mb-2"}>
                    <a
                      class="hover:text-primary hover:underline"
                      href={item.url}
                    >
                      {item.name}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="flex flex-col ml-8">
            <h6>Contacto</h6>
            <ul>
              <li class="mb-4 flex items-center">
                <span set:html={markdownify(location)} />
              </li>

              <li class="mb-2 flex items-center">
                <Icon name="Envelope" size={20} className="mr-2" />
                <a class="hover:text-primary" target="_blank" rel="noopener noreferrer" href={`mailto:${email}`}>
                  {email}
                </a>
              </li>

              <li class="mb-2 flex items-center">
                <Icon name="WhatsappLogo" size={20} className="mr-2" />
                <a class="hover:text-primary hover:underline" target="_blank" rel="noopener noreferrer" href={`${whatsapp}`}>
                  {phone}
                </a>
              </li>

              <li class="mb-2 flex items-center">
                <Icon name="InstagramLogo" size={20} className="mr-2" />
                <a
                  class="hover:text-primary hover:underline"
                  href={`${instagram}`}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span>Instagram</span>
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container max-w-[1440px]">
    <div
      class="footer-copyright mx-auto border-t border-border pb-10 pt-7 text-left"
    >
    <p class="content text-text">
      {copyright.replace("2026", currentYear.toString())}      
    </p>
    </div>
  </div>
</footer>
